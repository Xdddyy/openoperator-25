// v110_40_probe_aten_gather
#include <torch/extension.h>
#include <stdint.h>
#include <cstdio>

#define BATCH 64
#define K_COL 32

torch::Tensor bang_func(torch::Tensor input, torch::Tensor index) {
    fprintf(stderr,
            "[ATEN_PROBE] enter dtype=%d index_dtype=%d\n",
            (int)input.scalar_type(),
            (int)index.scalar_type());
    fflush(stderr);

    // input: [64,1024]
    // index: [64,32]
    // gather dim=1
    return input.gather(1, index);
}